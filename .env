# Параметры базы данных PostgreSQL
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=fastapi_pass
POSTGRES_DB=fastapi_db

# URL для подключения FastAPI к БД (используется внутри Docker-сети)
DATABASE_URL=postgresql://fastapi_user:fastapi_pass@db:5432/fastapi_db

# URL для подключения FastAPI к Redis (используется внутри Docker-сети)
REDIS_URL=redis://redis:6379/0